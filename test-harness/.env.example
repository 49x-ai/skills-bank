# Copy to .env and fill in. .env is gitignored.

# Long-lived OAuth token from `claude setup-token`.
# Required for container runs (sandbox HOME has no keychain).
# Optional for host runs (claude reads keychain on macOS).
#   claude setup-token   # opens browser, prints the token to copy here
CLAUDE_CODE_OAUTH_TOKEN=

# Tier 2 — dedicated test bot from @BotFather.
# Required for any driver under test-harness/drivers/tier2/.
# Format: <bot_id>:<35+ alnum/underscore/hyphen chars>.
TEST_BOT_TOKEN=

# Tier 2 — chat-id where the test bot will send messages.
# Easiest capture: DM the new bot once, then
#   curl -s "https://api.telegram.org/bot$TEST_BOT_TOKEN/getUpdates" | jq
# Look for result[0].message.chat.id.
TEST_CHAT_ID=

# Tier 2 — your Telegram user-id (the sender that will be paired).
# Same getUpdates call: result[0].message.from.id.
TEST_SENDER_ID=
